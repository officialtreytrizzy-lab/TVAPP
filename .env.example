# Trecut/eTreyser video erase integration.
# The browser calls /api/v1/trecut/eraser/* by default.
# Keep the real generated tve_live_* token in server/Vercel env only.
TRECUT_ETREYSER_API_KEY=

# Optional: override the licensed Trey Video API base URL.
# Leave blank when the API lives in this same TVAPP deployment.
TRECUT_ETREYSER_API_BASE_URL=
TREY_VIDEO_API_PUBLIC_BASE_URL=

# Optional: override or disable the client proxy path.
VITE_TRECUT_ERASER_PROXY_URL=/api/v1/trecut/eraser
VITE_TRECUT_ERASER_USE_PROXY=true

# Optional direct worker fallback for local/internal testing only.
# The default app path should stay on the server-side proxy above.
VITE_ERASER_GPU_WORKER_URL=
